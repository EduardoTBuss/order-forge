# Copy this file to `.env`.
# Do NOT commit `.env`.

# ------------------------------------------------------------------------------
# Docker Compose project naming
# ------------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=invoice-workshop

# ------------------------------------------------------------------------------
# Backend API key
# Shared API key:
# - frontend uses it to call the backend proxy
# - backend uses it for HTTPBearer auth
# ------------------------------------------------------------------------------
BACKEND_API_KEY=dev-secret

# ------------------------------------------------------------------------------
# Frontend -> Backend (docker network)
# IMPORTANT: inside docker, use the service name `backend`, not localhost.
# ------------------------------------------------------------------------------
BACKEND_API_URL=http://backend:8000

# ------------------------------------------------------------------------------
# Postgres
# These are used to initialize the postgres container and connect the backend.
# docker-compose overrides POSTGRES_HOST/POSTGRES_PORT for the backend container.
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ------------------------------------------------------------------------------
# Blob storage — local Azurite emulator (these are the well-known public Azurite
# dev credentials, NOT a real Azure account). docker-compose overrides these.
# ------------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;EndpointSuffix=core.windows.net

# ------------------------------------------------------------------------------
# Cosmos DB (Mongo API) — local container.
# docker-compose overrides this to use the local cosmosdb service.
# ------------------------------------------------------------------------------
AZURE_COSMOSDB_CONNECTION_STRING=mongodb://localhost:27017/

# ------------------------------------------------------------------------------
# Frontend (Next.js)
# This workshop template ships a dev stub login (a fake local user) instead of a
# real identity provider, so no auth credentials are required.
# ------------------------------------------------------------------------------
FRONTEND_PORT=3000

# ----------------------------------------------------------------------------
# Order Intake — Stage 2 LLM extraction (optional, BYO local model)
# ----------------------------------------------------------------------------
# The "llm" customer strategy reads any PDF with a small local model served by
# Ollama (OpenAI-compatible API). Leave OI_LLM_BASE_URL empty to keep it off.
# To enable: install Ollama, pull a light model, then set:
#   ollama pull qwen2.5:1.5b     # light; fits ~2GB RAM (use qwen2.5:0.5b if even tighter)
# From the Docker containers, reach the host's Ollama via host.docker.internal.
OI_LLM_BASE_URL=
# OI_LLM_BASE_URL=http://host.docker.internal:11434/v1
OI_LLM_MODEL=qwen2.5:1.5b
OI_LLM_API_KEY=ollama
